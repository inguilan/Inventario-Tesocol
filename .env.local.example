# ─── NextAuth ───────────────────────────────────────────────
# Genera un secreto seguro con: openssl rand -base64 32
NEXTAUTH_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_SEGURO
NEXTAUTH_URL=http://localhost:3000

# ─── Credenciales del sistema ───────────────────────────────
# Puedes agregar más usuarios separados por coma en el futuro
# Formato: usuario:contraseña hasheada (bcrypt)
# Por ahora usamos credenciales simples para empezar
ADMIN_USERNAME=admin
ADMIN_PASSWORD=tesocol2025
ADMIN_NAME=Administrador Tesocol

